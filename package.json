{
  "name": "omni-link-hustlexp",
  "version": "1.0.0",
  "description": "HustleXP-tailored multi-repo engineering control plane for Claude Code",
  "type": "module",
  "main": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sebdysart/omni-link-hustlexp.git"
  },
  "bugs": {
    "url": "https://github.com/Sebdysart/omni-link-hustlexp/issues"
  },
  "homepage": "https://github.com/Sebdysart/omni-link-hustlexp#readme",
  "keywords": [
    "claude-code",
    "plugin",
    "multi-repo",
    "ecosystem",
    "tree-sitter",
    "code-analysis",
    "hustlexp",
    "swift",
    "trpc",
    "authority-gates"
  ],
  "bin": {
    "omni-link": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "benchmark:hustlexp:live": "node scripts/hustlexp-live-benchmark.mjs",
    "benchmark:smoke": "node scripts/benchmark-smoke.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "pack:check": "npm pack --dry-run",
    "smoke:cli": "node scripts/cli-smoke.mjs",
    "smoke:contracts": "node scripts/contract-fixture-smoke.mjs",
    "smoke:max": "node scripts/max-tier-smoke.mjs",
    "smoke:package": "node scripts/package-install-smoke.mjs",
    "stress:full": "node scripts/full-stress.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:providers:live": "vitest run tests/providers/live.integration.test.ts",
    "test:providers:live:if-configured": "node scripts/live-provider-test-gate.mjs",
    "test:watch": "vitest",
    "lint": "eslint . && tsc --noEmit",
    "prepare": "husky",
    "review:pr": "node dist/cli.js review-pr --base main --head HEAD",
    "verify": "npm run lint && npm test && npm run test:coverage && npm run build && npm run smoke:cli && npm run benchmark:smoke && npm run pack:check",
    "verify:max": "npm run verify && npm run smoke:max && npm run smoke:contracts && npm run smoke:package",
    "verify:stress": "npm run verify:max && npm run stress:full && npm run test:providers:live:if-configured",
    "verify:hustlexp": "npm run verify:max && npm test -- tests/authority/index.test.ts tests/bridges/swift-trpc.test.ts tests/integration/hustlexp-profile.test.ts tests/runtime/index.test.ts tests/cli-app.test.ts tests/scripts/hustlexp-live-benchmark.test.ts"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "Sebastian Dysart",
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "agents",
    "commands",
    "config",
    "hooks",
    "skills"
  ],
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.46.0",
    "@typescript-eslint/parser": "^8.46.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^8.57.1",
    "husky": "^9.1.7",
    "prettier": "^3.6.2",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "gpt-tokenizer": "^3.4.0",
    "graphql": "^16.13.1",
    "ignore": "^7.0.5",
    "p-limit": "^7.1.1",
    "sql.js": "^1.14.1",
    "tree-sitter": "^0.25.0",
    "tree-sitter-go": "^0.23.0",
    "tree-sitter-java": "^0.23.0",
    "tree-sitter-javascript": "^0.23.0",
    "tree-sitter-python": "^0.23.0",
    "tree-sitter-rust": "^0.23.0",
    "tree-sitter-swift": "^0.7.1",
    "tree-sitter-typescript": "^0.23.0",
    "typescript": "^5.7.0",
    "zod": "^4.1.11"
  },
  "overrides": {
    "brace-expansion": ">=1.1.13",
    "picomatch": ">=4.0.4"
  }
}
